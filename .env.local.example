# GitHub Personal Access Token used by lib/github.ts to fetch live
# contribution data for the homepage. Without it, the hero falls back
# to the static snapshot in lib/heatmap.json + lib/github-data.ts.
#
# 1. Create at: https://github.com/settings/tokens?type=beta
# 2. Required scopes:
#       - public_repo            (read public commits/PRs)
#       - read:user              (read user profile)
#       - read:org               (contributions across indpro-blr orgs)
# 3. Copy this file to .env.local and paste the token below.
# 4. On Vercel: add GITHUB_TOKEN to Project Settings > Environment Variables.

GITHUB_TOKEN=
